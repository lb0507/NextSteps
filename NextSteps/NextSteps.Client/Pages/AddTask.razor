@using BlazorBootstrap
@using DataLibrary.Models;
@using DataLibrary.ServiceLayer.TaskService;
@using DataLibrary.ServiceLayer.FuneralService;
@using DataLibrary.ServiceLayer.NoteService;
@using NextSteps.Client.Components
@using NextSteps.Client.Shared

<!-- Inject Services -->
@inject NavigationManager _nav
@inject BrowserStorageService _storage
@inject ITaskService _task
@inject IFuneralService _funeral
@inject INoteService _notes

<!-- Allows user to interact -->
@rendermode InteractiveServer

<!-- Override MainLayout from Server and use Client's Custom Layout-->
@layout CustomLayout

@page "/add-task/{category}"
@page "/task/{taskId:guid}"

<!-- Screen Message Modal -->
<ScreenModal @ref="modal" TitleText="@modalTitle" BodyText="@modalBody" URL="@modalURL"/>


<!-- Modal for view Notes attached to the Task -->
<Modal @ref="notesModal" Title="@(newNote? "New Note" : "Task Note")" 
    IsVerticallyCentered
    Size="ModalSize.Large"
    Class="note-modal">
    <BodyTemplate>

        @if (newNote)
        {
            <div class="modal-body">
                <textarea class="notes-desc-input"
                          @bind="newNoteText"
                          rows="8"/>
            </div>
        }
        else
        {
            <div class="modal-body">
                <textarea class="notes-desc-input"
                          @bind="selectedNote.NoteText" 
                          readonly
                          rows="8" />
            </div>

            <div class="modal-body">
                <label>Creation Date:</label>
                <span>@selectedNote.CreationDate.ToString("dd MMM yyyy HH:mm")</span>
            </div>
        }

    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="OnHideModalClick">Close</Button>
        
        @if (newNote)
        {
            <Button Color="ButtonColor.Primary" @onclick="HandleAttachNote">Save</Button>
        }
        else
        {
            <Button Color="ButtonColor.Danger" @onclick="HandleNoteDeletion">Delete</Button>
        }

    </FooterTemplate>
</Modal>


<!-- Modal for Confirming the Deletion of the Task -->
<Modal @ref="confirmationModal" Title="Confirm Deletion?"
       IsVerticallyCentered
       Size="ModalSize.Regular"
       >
    <BodyTemplate>

        <div class="modal-body">
            <span>Please confirm that you would like to delete this task. This action cannot be undone.</span>
        </div>

    </BodyTemplate>
    <FooterTemplate>

        <Button Color="ButtonColor.Secondary" @onclick="confirmationModal.HideAsync">Cancel</Button>
        
        <Button Color="ButtonColor.Danger" @onclick="HandleTaskDeletion">Delete</Button>

    </FooterTemplate>
</Modal>


<div class="page-container" style="display: flex; width: 100%;  height: 85vh;">
    
    <div class="task-details" style=" width: 70%; border-right: 1px solid midnightblue; height: 100%">

        @if (taskId is null)
        {
            <h3>Add Task</h3>
        }
        else
        {
            <h3>Task Details</h3>
        }

        <table style="width: 98%;">

            <colgroup>
                <col span="1" style="width: 16%" />
            </colgroup>
            <colgroup>
                <col span="1" style="width: 84%" />
            </colgroup>

            <!-- TASK NUMBER -->
            <tr>
                <td>
                    <label>Task Number</label>
                </td>

                <td>
                    <!-- Display the Task Number -->
                    @if (taskId is null)
                    {
                        <input type="text"
                               readonly
                               value="Provided by System" />
                    }
                    else
                    {
                        <input type="text"
                               readonly
                               @bind="task.TaskNumber" />
                    }
                </td>
            </tr>

            <!-- TASK DESCRIPTION -->
            <tr>
                <td style="display: flex; vertical-align: top;">
                    <label>Task Description</label>
                </td>

                <td>
                    <!-- Input field for the Task Description -->
                    <textarea type="text"
                           @bind="task.Description"
                           rows="12"
                           style="width: 100%; resize: none"/>
                </td>
            </tr>

            <!-- TASK CATEGORY -->
            <tr>
                <td>
                    <label>Task Category</label>
                </td>

                <td>
                    @if (category is null)
                    {
                        <input type="text"
                               readonly
                               value="@task.Category" />
                    }
                    else
                    {
                        <input type="text"
                               readonly
                               value=@(category) />
                    }
                </td>
            </tr>
        
            <!-- TASK STATUS -->
            <tr>
                <td>
                    <label>Task Status</label>
                </td>

                <td>
                    <!-- Selection menu for the Task Status -->
                    <InputSelect style="height: 4vh; width: 15%" @bind-Value="@task.IsComplete">

                        <option value="false">Incomplete</option>
                        <option value="true">Completed</option>
                        
                    </InputSelect>
                </td>
            </tr>

            <!-- TASK CREATION DATE -->
            <tr>
                <td>
                    <label>Creation Date</label>
                </td>

                <td>
                    <!-- Display the Creation Date -->
                    @if (taskId is null)
                    {
                        <input type="text"
                               readonly
                               value="Provided by System" />
                    }
                    else
                    {
                        <input type="text"
                               readonly
                               value=@(task.CreationDate.ToString("dd MMM yyyy HH:mm")) />
                    }
                </td>
            </tr>

            <!-- TASK COMPLETION DATE -->
            <tr>
                <td>
                    <label>Completion Date</label>
                </td>

                <td>
                    <!-- Time Picker Input for the Completion Date -->
                    <input type="date"
                           @bind="@task.CompletionDate"
                           ShowSeconds="false" />
                </td>
            </tr>

        </table>

        <div class="task-buttons">

            <Button Type="ButtonType.Link" Color="ButtonColor.Secondary" To="@($"/{backURL}")">Back</Button>

            @if (taskId is not null)
            {
                <Button Color="ButtonColor.Danger" @onclick="HandleTaskDeletionConfirmation">Delete Task</Button>
            }
            
            <Button Color="ButtonColor.Primary" @onclick="HandleSave">Save Task</Button>

        </div>
    </div>
    
    <div class="notes-section" style="width: 30%; padding-left: 20px; height: 100%;">
        <div class="notes-table" style="max-height: 95%; overflow: auto; background-color: lightgray">

            <!-- Table of Notes for this Task-->
            <Grid TItem="Note"
                  @ref="grid"
                  AllowSorting="true"
                  AllowRowClick="true"
                  OnRowDoubleClick="OnRowDoubleClick"
                  Class="table table-hover table-bordered table-striped"
                  DataProvider="TasksDataProvider"
                  Responsive="true"
                  RowKeySelector="(note) => note.NoteId">

                <GridColumns>

                    <!-- Note Text Column -->
                    <GridColumn TItem="Note" HeaderText="Note Text" PropertyName="NoteText" SortKeySelector="item => item.NoteText" Class="note-col">
                        @context.NoteText
                    </GridColumn>

                    <!-- CreationDate Column -->
                    <GridColumn TItem="Note" HeaderText="Date" PropertyName="CreationDate" SortKeySelector="item => item.CreationDate" Class="date-col">
                        @(context.CreationDate.ToString("dd MMM yyyy HH:mm"))
                    </GridColumn>
            
                </GridColumns>

            </Grid>

        </div>

        <div class="notes-buttons">
            <Button Color="ButtonColor.Secondary" @onclick="() => OnShowModalClick(true)">Attach Note</Button>
        </div>

    </div>

</div>

@code {
    [Parameter]
    public Guid? taskId { get; set; }

    [Parameter]
    public string? category { get; set; }

    private string backURL = "";

    private NsTask task = new();
    private bool taskStatus = false;

    private User currentUser = new();

    private Funeral currentFuneral = new();

    #region[MODAL]
    private ScreenModal modal = default!;
    private Modal confirmationModal = default!;
    private string modalTitle = string.Empty;
    private string modalBody = string.Empty;
    private string modalURL = string.Empty;
    #endregion

    #region [GRID]

    private BlazorBootstrap.Grid<Note>? grid;

    private List<Note> Notes = new();
    private List<Note> NewNotes = new();

    private Note selectedNote = new();

    private async Task<GridDataProviderResult<Note>> TasksDataProvider(GridDataProviderRequest<Note> request) => await Task.FromResult(request.ApplyTo(Notes));

    // On Clicking a row in the table, open a modal displaying the details of the Note
    private async Task OnRowDoubleClick(GridRowEventArgs<Note> args)
    {
        selectedNote = args.Item;
        await OnShowModalClick(false);
    }

    #endregion

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Get the current user from browser storage
            currentUser = await _storage.GetFromStorage<User>("currentUser") ?? new();

            // Check if the user is signed in. If not, navigate them to the Sign In page
            if (currentUser is null)
                _nav.NavigateTo("/");

            currentFuneral = await _storage.GetFromStorage<Funeral>("currentFuneral") ?? new();

            // If a TaskId was passed in through the URL, use it to pull the Task object
            if (taskId is not null)
            {
                // Fetch the Task details
                task = await _task.GetTask(taskId ?? Guid.Empty) ?? new();

                // Fetch the notes attached to this task
                Notes = await _notes.GetNotes(taskId ?? Guid.Empty);

                // Refresh the Notes grid
                if (grid is not null)
                    await grid.RefreshDataAsync();
            }
            else
            {
                // Set the category of the task if the category was passed in through the url
                task.Category = category ?? "Uncategorized";
            }

            // Set the url for the back button
            switch (task.Category)
            {
                case "Florist":
                case "Photography":
                case "Catering":
                case "Music":
                    backURL = $"Vendors-{task.Category}";
                    break;
                default:
                    backURL = task.Category;
                    break;
            }

            StateHasChanged();
        }
    }

    // Create or Update the Task
    private async Task HandleSave()
    {
        // Display an error message to the user if they attempt to save a Task without entering a description
        if (string.IsNullOrWhiteSpace(task.Description))
        {
            modalTitle = "Error";
            modalBody = "Task description cannot be empty. Please enter a description and try again.";
            await modal.OnShowModalClick();
            return;
        }

        NsTask? result = null;

        if (taskId is null)
        {
            task.FuneralId = currentFuneral.FuneralId;
            task.TaskNumber = $"Task-{currentFuneral.NumberOfTasks + 1}";

            // Create the Task
            result = await _task.CreateTask(task);
        }
        else
        {
            // Update the Task
            result = await _task.UpdateTask(task);
        }

        if (result is not null)
        {
            // Update the number of tasks for the funeral if the task is new
            if (taskId is null)
            {
                currentFuneral = await _funeral.UpdateTaskNumber(currentFuneral) ?? new();
                await _storage.SetInStorage("currentFuneral", currentFuneral);
            }            

            // Display success message to user and redirect them back to the category page
            modalTitle = "Save Successful";
            modalBody = "The task has been saved successfully.";
            modalURL = $"/{backURL}";
            await modal.OnShowModalClick();
        }
        else
        {
            // Display error message to user
            modalTitle = "Error";
            modalBody = "An error occurred and the task was not saved.";
            await modal.OnShowModalClick();
        }
    }

    private async Task HandleTaskDeletionConfirmation() => await confirmationModal.ShowAsync();

    private async Task HandleTaskDeletion()
    {
        await confirmationModal.HideAsync();

        var result = await _task.DeleteTask(taskId ?? Guid.Empty);

        if (result)
        {   // Task Deletion Successful

            // Display confimation message to user
            modalTitle = "Deletion Confirmed";
            modalBody = "The task has been deleted.";
            modalURL = $"/{backURL}";
            await modal.OnShowModalClick();
        }
        else
        {   // Task Deletion Failed

            // Display error message to user
            modalTitle = "Error";
            modalBody = "An error occurred and the task was not deleted.";
            await modal.OnShowModalClick();
        }
    }

    #region[NOTE/MODAL METHODS]

    private Modal notesModal = default!;
    private bool newNote = false;
    private string newNoteText = string.Empty;

    // Show Notes modal, passed boolean determines if it is a Create Note modal or View/Delete Note modal
    public async Task OnShowModalClick(bool isNew)
    {
        if (isNew)
            newNote = true;
        else
            newNote = false;

        await notesModal.ShowAsync();
    }

    // Close Notes modal
    private async Task OnHideModalClick()
    {
        newNoteText = string.Empty;
        await notesModal.HideAsync();
    }

    // Create a Note
    private async Task HandleAttachNote()
    {
        // Display an error message to the user if they attempt to save a note without entering any text
        if (string.IsNullOrWhiteSpace(newNoteText))
        {
            modalTitle = "Error";
            modalBody = "Note cannot be empty. Please enter a note and try again.";
            modalURL = string.Empty;
            await modal.OnShowModalClick();
            return;
        }

        // Create or Update the Task
        var result = await _notes.CreateNote
        (
            new Note
            {
                NoteText = newNoteText,
                ObjectId = task.TaskId
            }
        );

        if (result is not null)
        {
            // Hide the modal
            await OnHideModalClick();

            // Add the New note to the Notes grid
            Notes.Add(result);

            // Refresh the grid
            if (grid is not null)
                await grid.RefreshDataAsync();

        }
        else
        {
            // Display error message to user
            modalTitle = "Error";
            modalBody = "An error occurred and the note was not saved.";
            await modal.OnShowModalClick();
        }
    }

    private async Task HandleNoteDeletion()
    {
        // Delete the selected Note
        var result = await _notes.DeleteNote(selectedNote.NoteId);

        // Hide the Note Modal
        await notesModal.HideAsync();

        if (result)
        {   // Note Deletion Successful

            //Remove the note from the table
            Notes.Remove(selectedNote);

            // Refresh the grid
            if (grid is not null)
                await grid.RefreshDataAsync();

            // Display confimation message to user
            modalTitle = "Deletion Confirmed";
            modalBody = "The note has been deleted.";
            await modal.OnShowModalClick();
        }
        else
        {   // Note Deletion Failed

            // Display error message to user
            modalTitle = "Error";
            modalBody = "An error occurred and the note was not deleted.";
            await modal.OnShowModalClick();
        }
    }

    #endregion
}
