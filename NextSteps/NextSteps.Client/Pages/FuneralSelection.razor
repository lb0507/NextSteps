    - Added Grid component
    - Added Create Funeral functionality
    ======================================
*@

@using BlazorBootstrap
@using DataLibrary.Models;
@using DataLibrary.ServiceLayer.FuneralService;
@using DataLibrary.ServiceLayer.UserService;
@using NextSteps.Client.Components
@using NextSteps.Client.Shared

<!-- Inject Services -->
@inject NavigationManager _nav
@inject BrowserStorageService _storage
@inject IFuneralService _funeral
@inject IUserService _user

<!-- Allows user to interact -->
@rendermode InteractiveServer

<!-- Override MainLayout from Server and use Client's Custom Layout-->
@layout CustomLayout

@page "/funeral-selection"

<!-- Preload Spinner -->
<Preload LoadingText="" />

<!-- Modal for Adding new Funerals -->
<Modal @ref="modal" Title="Add New Funeral Service" IsVerticallyCentered>
    <BodyTemplate>
        
        <table style="width: 100%">

            <colgroup>
                <col span="1" style="width: 35%;" />
            </colgroup>
            <colgroup>
                <col span="1" style="width: 65%;" />
            </colgroup>

            <tr>
                <td class="modal-cell">
                    <label>
                        Name of Deceased:
                    </label>
                </td>
                <td class="modal-cell">
                    <input @bind="name" style="width: 90%"/>
                </td>
            </tr>
            <tr>
                <td class="modal-cell">
                    <label>
                        Date of Service:
                    </label>
                </td>
                <td class="modal-cell">
                    <input type="date"
                           @bind="@date"
                           ShowSeconds="false" />
                </td>
            </tr>
            <tr>
                <td class="modal-cell">
                    <label>
                        Location of Service:
                    </label>
                </td>
                <td class="modal-cell"
                    <input @bind="location" style="width: 90%" />
                </td>
            </tr>

        </table>
        
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="OnHideModalClick">Back</Button>
        <Button Color="ButtonColor.Primary" @onclick="HandleFuneralCreate">Create</Button>
    </FooterTemplate>
</Modal>

<!-- Screen Message Modal for Funeral creation errors -->
<ScreenModal @ref="resultModal" TitleText="@modalTitle" BodyText="@modalBody" URL="@modalURL" />

<div class="page-container">

    <div class="header-row">
        <!-- Page Headers -->
        <h1>Funeral Selection</h1>

        <!-- Radio buttons for choosing which funerals to view -->
        <div class="radio-buttons">
            <label style="font-size: 18px; margin-right: 20px">Funeral View:</label>
            <InputRadioGroup Value="showArchived" ValueExpression="() => showArchived" ValueChanged="OnSelectionChanged" TValue="bool">
                <div class="radio-option"> <InputRadio Value="false" /> Active </div>
                <div class="radio-option"> <InputRadio Value="true" /> Archived </div>
            </InputRadioGroup>
        </div>
    </div>  
             
    <!-- Table of Funeral objects -->
    <Grid TItem="Funeral"
            @ref="grid"
            AllowFiltering="true"
            AllowPaging="true"
            AllowSorting="true"
            AllowRowClick="true"
            OnRowDoubleClick="OnRowDoubleClick"
            Class="table table-hover table-bordered table-striped"
            DataProvider="FuneralsDataProvider"
            PageSize="10"
            Responsive="true">

        <GridColumns>
            <!-- Name of Deceased Column -->
            <GridColumn TItem="Funeral" HeaderText="Deceased" PropertyName="DeceasedName" SortKeySelector="item => item.DeceasedName" Class="name-col">
                @context.DeceasedName
            </GridColumn>

            <!-- Location Column -->
            <GridColumn TItem="Funeral" HeaderText="Location" PropertyName="Location" SortKeySelector="item => item.Location" Class="location-col">
                @context.Location
            </GridColumn>

            <!-- Date of Service Column -->
            <GridColumn TItem="Funeral" HeaderText="Service Date" PropertyName="DateOfService" SortKeySelector="item => item.DateOfService" Class="date-col text-center" >
                @(context.DateOfService?.ToString("dd MMM yyyy h:mm tt") ?? string.Empty)
            </GridColumn>

        </GridColumns>

    </Grid>

    <div class="buttons">

        @if (showArchived == false)
        {
            <!-- Add a New Funeral -->
            <Button Color="ButtonColor.Primary" @onclick="OnShowModalClick">Add Funeral</Button>
        }

        <!-- Refresh the Grid -->
        <Button Color="ButtonColor.Secondary" @onclick="@(async () => { await OnAfterRenderAsync(true); })">Refresh</Button>

    </div>

</div>

@code {

    [Inject]
    protected PreloadService PreloadService { get; set; } = default!;

    private List<Funeral> Funerals = new();
    private List<Funeral> Archives = new();

    private User? currentUser;

    #region[MODAL]
    private ScreenModal resultModal = default!;
    private Modal modal = default!;
    private string modalTitle = string.Empty;
    private string modalBody = string.Empty;
    private string modalURL = string.Empty;
    #endregion

    private string name = "";
    private DateTime? date;
    private string? location;

    private bool showArchived = false;

    #region [GRID]

    private BlazorBootstrap.Grid<Funeral>? grid;

    private async Task<GridDataProviderResult<Funeral>> FuneralsDataProvider(GridDataProviderRequest<Funeral> request) => await Task.FromResult(request.ApplyTo(Funerals.Where(f => f.IsArchived == showArchived)));

    private async Task OnRowDoubleClick(GridRowEventArgs
    <Funeral> args)
    {
        await _storage.SetInStorage("currentFuneral", args.Item);

        _nav.NavigateTo("/funeral");
    }

    #endregion

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            PreloadService.Show(SpinnerColor.Dark);

            // Get the current user from browser storage
            currentUser = await _storage.GetFromStorage<User>("currentUser") ?? new();

            // Check if the user is signed in. If not, navigate them to the Sign In page
            if (currentUser is null)
            {
                _nav.NavigateTo("/");
            }
            else
            {
                // Clear the selected Funeral
                await _storage.RemoveFromStorage("currentFuneral");

                Funerals = await _funeral.GetFunerals(currentUser?.UserId ?? Guid.Empty);

                // A short pause to ensure the funeral data loads before the grid is refreshed
                await Task.Delay(400);

                // Refresh the grid
                if(grid is not null)
                    await grid.RefreshDataAsync();

                PreloadService.Hide();
            }
        }
    }

    // Handle creation of the funeral event
    private async Task HandleFuneralCreate()
    {
        // Check that a name has been entered for the deceased
        if (string.IsNullOrEmpty(name))
        {
            await OnHideModalClick();

            modalTitle = "Error";
            modalBody = "The name of the deceased can not by empty. Please enter a name and try again.";
            await resultModal.OnShowModalClick();
        }
        else
        {
            // Create the funeral
            var result = await _funeral.CreateFuneral
            (
                new Funeral
                {
                    DeceasedName = name,
                    UserId = currentUser?.UserId ?? Guid.Empty,
                    DateOfService = date,
                    Location = location
                }
            );

            if (result is not null)
            {
                // The funeral creation was successful, add it to the table
                Funerals.Add(result);

                // Refresh the grid
                if (grid is not null)
                    await grid.RefreshDataAsync();
                await OnHideModalClick();

                // Show the user a modal to inform them of how they can modify/delete the funeral
                modalTitle = "Success";
                modalBody = "To modify or delete the funeral, go to the \"Info\" tab of the \"Funeral Info\" category.";
                await resultModal.OnShowModalClick();
            }
            else
            {
                // There was an error during funeral creation, inform the user
                await OnHideModalClick();

                modalTitle = "Error";
                modalBody = "An error occurred during creation of the Funeral. Please validate your input and try again.";
                await resultModal.OnShowModalClick();
            }
        }
    }

    // Show the funeral creation modal
    private async Task OnShowModalClick() => await modal.ShowAsync();

    // Hide the funeral creation modal
    private async Task OnHideModalClick()
    {
        // Reset the information in the modal
        name = string.Empty; 
        date = null;
        location = null;

        await modal.HideAsync();
        await Task.CompletedTask;
    }

    // Handle the change in the radio buttons
    private async Task OnSelectionChanged(bool value)
    {
        showArchived = value;
        if (grid is not null) 
            await grid.RefreshDataAsync();
    }
}
