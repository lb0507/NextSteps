@*
    User Sign-In Page
    3/13/2026
    ======================================
    - Initial page creation
    - Added Sign In funcitonality and input field validation
    ======================================
*@

@using BlazorBootstrap;
@using DataLibrary.Models;
@using DataLibrary.ServiceLayer.UserService;
@using System.ComponentModel.DataAnnotations;
@using NextSteps.Client.Components
@using NextSteps.Client.Shared

<!-- Injections -->
@inject IUserService _user
@inject BrowserStorageService _storage
@inject NavigationManager _nav

<!-- Override MainLayout from Server and use Client's Custom Layout-->
@layout SignedOutLayout

<!-- Link to the page -->
@page "/"

<!-- Allows user to interact -->
@rendermode InteractiveServer

<!-- Screen Message Modal for invalid log in prompt -->
<ScreenModal @ref="modal" TitleText="Login Failed" BodyText="The credentials you have entered are invalid. Please check your email and password and try again." />

<!-- Page Title -->
<div class="signed-out-title">

    <h1 class="title">NextSteps</h1>

    <h1>Sign-In</h1>

</div>

<!-- Sign in Form -->
<EditForm EditContext="editContext" OnValidSubmit="@HandleLogin" FormName="signInForm" style="width: 500px">
    <DataAnnotationsValidator />
    <ValidationSummary/>

    <div class="input-field"> <!-- Email input field -->
        <InputText @bind-Value="user.Email" style="height: 4vh; width: 100%" class="form-field" placeholder="Email" />
            <ValidationMessage For="() => user.Email" />
    </div>

    <div class="input-field">
        <!-- Password input field-->
        <InputText @bind-Value="user.Password" style="height: 4vh; width: 100%" class="form-field" type="@pwVisibility" placeholder="Password" />
            <ValidationMessage For="() => user.Password" />
        <!-- CheckBox for toggling password visibility -->
        <div id="chkbx">
            <input type="checkbox" id="show-password" @onclick="@(() => { showPassword = !showPassword; pwVisibility = showPassword ? "text" : "password"; })">
            <label for="show-password"> Show </label>
        </div>
    </div>

    <div class="btm-buttons">
        <!-- Sign In button -->
        <Button type="ButtonType.Submit" Color="ButtonColor.Primary">Sign In</Button>
            
        <!-- Clear Form button -->
        <Button Color="ButtonColor.Secondary" @onclick="HandleClearForm">Clear Form</Button>
    </div>

</EditForm>



<!-- Link to Sign Up Page -->
<p><i>Don't have an account?</i> <a href="/signup">Sign Up</a> </p>

@code {
    private EditContext? editContext;
    private SignInModel user = new SignInModel();

    private bool showPassword = false;
    private string pwVisibility = "password";
    private string email = "";
    private string password = "";

    private ScreenModal modal = default!;


    // Model for validating input fields during user sign-in
    public record SignInModel : IValidatableObject
    {
        [Required(ErrorMessage = "Please input an email address.")]
        [EmailAddress(ErrorMessage = "Please input a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Please input a password.")]
        public string Password { get; set; } = "";

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            return new List<ValidationResult>();
        }
    }

    #region[METHODS]

    protected override async Task OnInitializedAsync()
    {
        // Make sure the input fields are empty upon loading the page
        HandleClearForm();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Get the current user from storage
            var currentUser = await _storage.GetFromStorage<User>("currentUser");

            // If user in browser storage is not null, automatically sign them in
            if (currentUser is not null)
            {
                Console.WriteLine($"User is now: {currentUser?.FirstName}");
                _nav.NavigateTo("/funeral-selection");
            }
        }
    }

    // Handle User Log In
    private async Task HandleLogin()
    {
        // Log in the user
        var result = await _user.LoginUser(user.Email, user.Password);

        if (result is not null)
        {
            // If login was valid, set the user in browser storage
            await _storage.SetInStorage("currentUser", result);

            _nav.NavigateTo("/funeral-selection");
        }
        else
            await modal.OnShowModalClick();
    }

    // Handle clearing the input fields
    private void HandleClearForm()
    {
        // Replace the user with a new instance
        user = new(); 

        // Replace the EditContext with a new instance
        editContext = new EditContext(user);
    }
    #endregion
}
