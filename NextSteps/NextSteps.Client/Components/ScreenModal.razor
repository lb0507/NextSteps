@using BlazorBootstrap

@inject NavigationManager _nav

<!-- Modal component with custom title -->
<Modal @ref="modal" Title=@TitleText>

    <!-- Body of the modal with custom text -->
    <BodyTemplate>
        @BodyText 
    </BodyTemplate>

    <!-- Button to close the modal -->
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="OnHideModalClick">Close</Button>
    </FooterTemplate>

</Modal>

@code {

    [Parameter]
    public string TitleText { get; set; } = string.Empty;

    [Parameter]
    public string BodyText { get; set; } = string.Empty;

    [Parameter]
    public string? URL { get; set; }

    private Modal modal = default!;


    // Open the modal
    public async Task OnShowModalClick() => await modal.ShowAsync();


    private async Task OnHideModalClick()
    {
        // Close the modal
        await modal.HideAsync();

        // If a URL was passed in, navigate to it after hiding the modal
        if (!string.IsNullOrEmpty(URL))
        {
            _nav.NavigateTo(URL);
        }
    }
}