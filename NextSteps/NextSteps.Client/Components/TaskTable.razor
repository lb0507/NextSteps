@*
    Task Table Component
    4/4/2026
    ======================================
    - Initial component creation
    - Added Task Progress Bar
    - Added Preloading Spinner and delay to ensure the data is loaded before the grid is refreshed
    ======================================
*@

@using BlazorBootstrap
@using DataLibrary.Models
@using DataLibrary.ServiceLayer.TaskService

@inject NavigationManager _nav
@inject BrowserStorageService _storage
@inject ITaskService _task

<!-- Preload Spinner -->
<Preload LoadingText=""/>

<!-- Progress Bar for Showing Percentage of Task Completion -->
<Progress Class="mb-3">
    <ProgressBar Width="@((completedTasks / allTasks)*100)" Label="@($"{(int)((completedTasks / allTasks)*100)}%")" Type="ProgressType.StripedAndAnimated" />
</Progress>

<div class="task-table-container">

    <!-- Task Table -->
    <div class="table-container">

        <!-- Table of Task objects -->
        <Grid TItem="NsTask"
              @ref="grid"
              AllowFiltering="true"
              AllowPaging="true"
              AllowSorting="true"
              AllowSelection="true"
              AllowRowClick="true"
              OnRowDoubleClick="OnRowDoubleClick"
              Class="table table-hover table-bordered table-striped"
              DataProvider="TasksDataProvider"
              PageSize="10"
              Responsive="true"
              RowKeySelector="(task) => task.TaskId"
              SelectedItemsChanged="OnSelectedItemsChanged"
              SelectionMode="GridSelectionMode.Multiple">

            <GridColumns>
                <!-- Task Number Column -->
                <GridColumn TItem="NsTask" HeaderText="Task Number" PropertyName="TaskNumber" SortKeySelector="item => item.TaskNumber">
                    @context.TaskNumber
                </GridColumn>

                <!-- Description Column -->
                <GridColumn TItem="NsTask" HeaderText="Description" PropertyName="Description" SortKeySelector="item => item.Description">
                    @context.Description
                </GridColumn>

                <!-- Status Column -->
                <GridColumn TItem="NsTask" HeaderText="Status" PropertyName="IsComplete" SortKeySelector="item => item.IsComplete">
                    @(context.IsComplete ? "Completed" : "Incomplete")
                </GridColumn>
            
            </GridColumns>

        </Grid>

    </div>

    <div class="buttons">

        <!-- Add a New Task -->
        <Button Color="ButtonColor.Primary" Type="ButtonType.Link" To=@($"/add-task/{Category}")>Add Task</Button>

        <!-- Refresh the Grid -->
        <Button Color="ButtonColor.Secondary" @onclick="@(async () => { if (grid is not null) await grid.RefreshDataAsync(); StateHasChanged(); })">Refresh</Button>

    </div>

</div>

@code {
    [Inject]
    protected PreloadService PreloadService { get; set; } = default!; 

    [Parameter, EditorRequired]
    public Guid FuneralId { get; set; }

    [Parameter, EditorRequired]
    public string Category { get; set; }

    private double completedTasks = 0;
    private double allTasks = 1;
    private int percent = 0;

    #region [GRID]

    private List<NsTask> Tasks = new();
    private BlazorBootstrap.Grid<NsTask>? grid;

    private HashSet<NsTask> selectedTasks = new();

    private async Task<GridDataProviderResult<NsTask>> TasksDataProvider(GridDataProviderRequest<NsTask> request) => await Task.FromResult(request.ApplyTo(Tasks));

    private Task OnSelectedItemsChanged(HashSet<NsTask> tasks)
    {
        selectedTasks = tasks is not null && tasks.Any() ? tasks : new();
        return Task.CompletedTask;
    }

    // On Clicking a row in the table, navigate to the details page of that corresponding Task
    private async Task OnRowDoubleClick(GridRowEventArgs<NsTask> args) => _nav.NavigateTo($"/task/{args.Item.TaskId}");

    #endregion

    protected override async Task OnParametersSetAsync()
    {
        PreloadService.Show(SpinnerColor.Dark);

        await base.OnParametersSetAsync();

        // Fetch the tasks for this category and Funeral
        Tasks = await _task.GetTasksByCategory(FuneralId, Category);

        // A short pause to ensure the task data loads before the grid is refreshed
        await Task.Delay(400);

        // Refresh the grid
        if (grid is not null)
            await grid.RefreshDataAsync();

        if (Tasks.Count() != 0)
        {
            completedTasks = Tasks.Where(t => t.IsComplete == true).Count();
            allTasks = Tasks.Count();
        }

        PreloadService.Hide();

        await InvokeAsync(StateHasChanged);
    }
}
